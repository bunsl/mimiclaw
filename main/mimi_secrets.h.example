#define MIMI_SECRET_SYSTEM_API_KEY          ""
#define MIMI_SECRET_SYSTEM_MODEL            ""
#define MIMI_SECRET_SYSTEM_MODEL_PROVIDER    ""

/* HTTP Proxy (leave empty or set both) */
